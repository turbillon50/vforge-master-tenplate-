# =============================================================================
# VForge Master Template — Environment Variables
# Copy to .env.local for local development.
# Never commit secrets. Production secrets live in Vercel project settings.
# =============================================================================

# ---- App ----
NEXT_PUBLIC_APP_NAME="VForge"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="es"
NEXT_PUBLIC_DEFAULT_THEME="dark"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"
NEXT_PUBLIC_COMPANY_NAME="Your Company"
NEXT_PUBLIC_COMPANY_LEGAL_NAME="Your Company S.A. de C.V."

# ---- Auth (Clerk) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/app"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/app"

# ---- Database (Neon Postgres + Drizzle) ----
DATABASE_URL=""

# ---- Payments — Stripe ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---- Payments — Mercado Pago ----
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""

# ---- Email — Resend ----
RESEND_API_KEY=""
RESEND_FROM_EMAIL="VForge <noreply@example.com>"

# ---- SMS / WhatsApp — Twilio ----
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_WHATSAPP_NUMBER=""

# ---- Maps — Google Maps ----
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ---- AI — OpenRouter (OpenAI-compatible) ----
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_DEFAULT_MODEL="anthropic/claude-3.5-sonnet"

# ---- Domains — Name.com ----
NAMECOM_USERNAME=""
NAMECOM_TOKEN=""

# ---- Storage (optional — for media manager) ----
STORAGE_PROVIDER="local"
BLOB_READ_WRITE_TOKEN=""
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ---- Vercel deployment integration (optional) ----
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""

# ---- Feature flags & environment ----
NODE_ENV="development"
NEXT_PUBLIC_APP_ENV="development"
